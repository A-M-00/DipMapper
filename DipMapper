def build_map_file_realpolitik(combined_region_information, filename):
    # This function can be used to convert the combined_region_information into the map file format used by Realpolitik
    def get_region_letters(region):
        letters = ""
        
        # Base type
        if region["type"] == "ocean":
            letters += "w"
        elif region["type"].endswith("island"):
            letters += "i"
        else:
            letters += "l"
        
        # Supply center modifiers
        if region["is_supply_center"]:
            if region["type"] == "neutral" or region["type"] == "island":
                letters += "x"
            else:
                letters += POWER_INITIALS_MAPPING.get(region["type"], "?")  # ? for unknown power (shouldn't happen)
        return letters
    
    # Create lookup from label to name
    label_to_name = build_dico(combined_region_information)

    with open(filename, "w") as f:

        # Section 1: Tiles
        for label, info in combined_region_information.items():
            name = info["name"]
            abbr = name.replace(" ", SPACE_REPLACER)
            letters = get_region_letters(info)
            f.write(f"{name}, {letters} {abbr}\n")

        # Separator
        f.write("-1\n")

        # Section 2: Adjacencies
        for label, info in combined_region_information.items():
            print("\nProcessing adjacencies for", info["name"])
            name = info["name"]
            neighbors = info["adjacency"]

            army_adjacencies = []
            fleet_adjacencies = []

            for neighbor_label in neighbors:
                neighbor = combined_region_information[neighbor_label]
                neighbor_name = neighbor["name"]

                # Army adjacency (mv)
                if is_land(info["type"]) and is_land(neighbor["type"]):
                    army_adjacencies.append(neighbor_name.replace(" ", SPACE_REPLACER))
                # Fleets case A: either province is sea
                if is_ocean(info["type"]) or is_ocean(neighbor["type"]):
                    fleet_adjacencies.append(neighbor_name.replace(" ", SPACE_REPLACER))
                # Case B: both land AND share a bordering sea
                elif is_land(info["type"]) and is_land(neighbor["type"]):
                # Find sea/island neighbors of both provinces
                    my_seas = {
                        n for n in info["adjacency"]
                        if combined_region_information[n]["type"] == "ocean" or is_island(combined_region_information[n]["type"])
                    }
                    neighbor_seas = {
                        n for n in neighbor["adjacency"]
                        if combined_region_information[n]["type"] == "ocean" or is_island(combined_region_information[n]["type"])
                    }

                    # If they share at least one sea province
                    if my_seas.intersection(neighbor_seas):
                        fleet_adjacencies.append(neighbor_name.replace(" ", SPACE_REPLACER))

            # Write results
            if army_adjacencies:
                f.write(f"{name}-mv: {' '.join(army_adjacencies)}\n")

            if fleet_adjacencies:
                f.write(f"{name}-xc: {' '.join(fleet_adjacencies)}\n")

        # Separator
        f.write("-1\n")

        # SECTION 3: Supply Center Order
        supply_centers = [
            info["name"]
            for info in combined_region_information.values()
            if info["is_supply_center"]
        ]

        for sc in supply_centers:
            f.write(f"{sc}\n")
    

