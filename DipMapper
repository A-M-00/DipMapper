def is_ocean(region_type):
    return region_type == "ocean" or region_type == "High Seas"
def is_island(region_type):
    return region_type.endswith("island")
def is_land(region_type):
    return not (is_ocean(region_type) or is_island(region_type))
def rgb_to_hex(rgb):
    return '#{:02x}{:02x}{:02x}'.format(*rgb)


def json_converter(o):
    if isinstance(o, np.integer):
        return int(o)
    if isinstance(o, np.floating):
        return float(o)
    if isinstance(o, np.ndarray):
        return o.tolist()
    if isinstance(o, set):
        return list(o)
    raise TypeError(f"Object of type {type(o)} is not JSON serializable")

def load_region_information(path="assets/halfway.json"):
    with open(path) as f:
        data = json.load(f)

    data = {int(k): v for k, v in data.items()}

    for region in data.values():
        region["adjacency"] = set(region["adjacency"])

    return data

def color_aware_label(image):  
    #Labels connected regions of identical color with unique labels. Only used if MULTICOLOUR_PROVINCES is False.
    color_ids = (
    image[..., 0].astype(np.int64) << 16 |
    image[..., 1].astype(np.int64) << 8  |
    image[..., 2].astype(np.int64)
    )
    mask = color_ids != 0
    structure = np.ones((3, 3))
    labels = np.zeros_like(color_ids)
    current_label = 1
    unique_ids = np.unique(color_ids[mask])

    for uid in unique_ids:
        region_mask = color_ids == uid
        labeled, num = ndimage.label(region_mask, structure=structure)

        for i in range(1, num + 1):
            labels[labeled == i] = current_label
            current_label += 1
    return labels, current_label - 1

